---
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__inner container">
    <div class="hero__content">
      <div class="location-badge hero-badge" aria-label="Service area">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
        </svg>
        Serving Vernon, BC &amp; the Okanagan
      </div>

      <h1 id="hero-heading" class="hero-h1">Professional Plumbing You Can Count On.</h1>

      <p class="hero__sub hero-sub">Licensed plumbing and gasfitting for homes and businesses across the North Okanagan. Honest pricing, quality workmanship, every time.</p>

      <div class="hero__ctas hero-ctas">
        <a href="tel:+12502411474" class="btn-primary">Call Now: +1 250-241-1474</a>
        <a href="#services" class="btn-secondary">View Our Services</a>
      </div>
    </div>

    <div class="hero__form-wrap">
      <div class="quote-form-card hero-form" role="form" aria-label="Request a free quote">
        <h3>Request a Free Quote</h3>
        <form id="hero-quote-form" novalidate>
          <div class="form-group">
            <label for="hero-name">Your Name</label>
            <input type="text" id="hero-name" name="name" placeholder="Jane Smith" autocomplete="name" required />
          </div>
          <div class="form-group">
            <label for="hero-phone">Phone Number</label>
            <input type="tel" id="hero-phone" name="phone" placeholder="+1 250-000-0000" autocomplete="tel" required />
          </div>
          <div class="form-group">
            <label for="hero-email">Email Address</label>
            <input type="email" id="hero-email" name="email" placeholder="jane@example.com" autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="hero-message">Describe Your Project</label>
            <textarea id="hero-message" name="message" placeholder="Tell us what you need — we'll get back to you quickly." rows="3"></textarea>
          </div>
          <button type="submit" class="btn-form" data-original="Get My Free Quote">Get My Free Quote</button>
          <div class="form-success" id="hero-form-success" role="status" aria-live="polite">
            Thanks! We'll be in touch shortly.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
