<div class="top-bar" role="banner" id="top-bar">
  <div class="top-bar__inner">
    <div class="top-bar__location" aria-label="Location: Enderby, BC">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
      </svg>
      Enderby, BC
    </div>
    <div class="top-bar__right">
      <a href="tel:+12502411474" class="top-bar__phone" aria-label="Call Branch Plumbing: +1 250-241-1474">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
        </svg>
        <span>+1 250-241-1474</span>
      </a>
      <a href="#contact" class="btn-quote-small">Get a Free Quote</a>
    </div>
  </div>
</div>

<script>
  const topBar = document.getElementById('top-bar');
  if (topBar) {
    function onScroll() {
      topBar.classList.toggle('scrolled', window.scrollY > 40);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
