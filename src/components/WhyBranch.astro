---
const whyItems = [
  {
    title: 'Licensed & Insured',
    desc: "Fully licensed plumber and certified gasfitter in British Columbia. You're covered on every job.",
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
  {
    title: 'Straightforward Pricing',
    desc: "We quote the job before we start and stick to it. No surprise line items when the invoice arrives.",
    icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  },
  {
    title: 'Clean, Thorough Work',
    desc: "We treat your home or jobsite with respect — work areas are left clean, and nothing is left half-done.",
    icon: '<polyline points="20 6 9 17 4 12"/>',
  },
  {
    title: 'Local to the Okanagan',
    desc: "Based in Enderby. No dispatch fees from a distant office — just your neighbour showing up and getting to work.",
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
  },
];

const reviews = [
  { text: '"Showed up on time, found the issue quickly, and had everything back in order the same day. Exactly what you want from a plumber."', author: 'D. Holloway, Enderby' },
  { text: '"Called about a water heater issue on a Friday afternoon. He came out, sourced the part, and had it done before the weekend. Highly recommend."', author: 'K. Parkes, Salmon Arm' },
  { text: '"Used Branch Plumbing for a bathroom renovation rough-in. Great communication, clean work, and the inspection passed first time."', author: 'M. Vander, Vernon' },
];

const starSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
const bigStarSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
const fbSvg = '<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>';
---

<section class="why-section" id="why" aria-labelledby="why-heading">
  <div class="container">
    <div class="why-grid">

      <!-- Left: copy -->
      <div>
        <span class="section-overline reveal">Why Branch Plumbing</span>
        <h2 id="why-heading" class="section-heading reveal">A Plumber You Can<br />Actually Count On</h2>
        <p class="reveal" style="color:var(--text-secondary);font-size:1.0625rem;line-height:1.65;max-width:52ch;margin-top:0;">
          We're not a franchise — we're a locally owned outfit that lives and works in this valley. That means faster response, personal accountability, and no upselling you don't need.
        </p>

        <div class="why-list">
          {whyItems.map(item => (
            <div class="why-item reveal">
              <div class="why-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
              </div>
              <div class="why-item-text">
                <h4>{item.title}</h4>
                <p>{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: reviews -->
      <div class="reviews-panel reveal" aria-label="Customer reviews">
        <div class="reviews-header">
          <div class="reviews-score">
            <span class="reviews-score-num">100%</span>
            <span class="reviews-score-label">Recommended</span>
          </div>
          <div>
            <div class="reviews-stars" aria-label="5 out of 5 stars">
              <Fragment set:html={bigStarSvg.repeat(5)} />
            </div>
            <p style="font-size:0.75rem;color:rgba(255,255,255,0.4);margin-top:4px;max-width:none;">10 reviews &middot; Facebook</p>
          </div>
        </div>

        <div class="reviews-list">
          {reviews.map(r => (
            <div class="review-item">
              <div class="review-stars" aria-label="5 stars">
                <Fragment set:html={starSvg.repeat(5)} />
              </div>
              <p class="review-text">{r.text}</p>
              <p class="review-author">
                {r.author}
                <span class="review-source">
                  <Fragment set:html={fbSvg} />
                  Facebook
                </span>
              </p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
